<Window x:Class="MKV_Converter.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:MKV_Converter"
        mc:Ignorable="d"
        Title="MKV to MP4 Converter" Height="600" Width="850" MinWidth="750" MinHeight="500"
        Icon="res/converter.ico">
    <Window.Resources>
        <local:BooleanToVisibilityConverter x:Key="BoolToVisConverter"/>
        <Style x:Key="BuyMeACoffeeButton" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" Background="{TemplateBinding Background}" Padding="3">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Effect">
                                    <Setter.Value>
                                        <DropShadowEffect ShadowDepth="0" Color="#3399ff" BlurRadius="15" Opacity="0.8"/>
                                    </Setter.Value>
                                </Setter>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="EmptyHintStyle" TargetType="StackPanel">
            <Setter Property="Visibility" Value="Collapsed"/>
            <Style.Triggers>
                <DataTrigger Binding="{Binding ElementName=QueueGrid, Path=HasItems}" Value="False">
                    <Setter Property="Visibility" Value="Visible"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,5">
            <Button x:Name="SelectFilesButton" Content="Select .mkv Files" Padding="10,5" Click="SelectFiles_Click"/>
            <Button x:Name="RemoveSelectedButton" Content="Remove Selected" Padding="10,5" Margin="5,0,0,0" Click="RemoveSelected_Click"/>
            <Button x:Name="ClearListButton" Content="Clear List" Padding="10,5" Margin="5,0,0,0" Click="ClearList_Click"/>
            <Button x:Name="SelectOutputButton" Content="Select Output Folder" Padding="10,5" Margin="5,0,0,0" Click="SelectOutput_Click"/>
            <Button x:Name="OpenFolderButton" Content="📂 Open Output Folder" Padding="10,5" Margin="5,0,0,0" IsEnabled="False" Click="OpenFolder_Click"/>
        </StackPanel>
        <TextBlock x:Name="OutputFolderLabel" Grid.Row="1" Text="Output to: Same as source file" Margin="0,0,0,5" Foreground="SlateGray"/>
        <!-- x:Name properties added here -->
        <TabControl x:Name="MainTabControl" Grid.Row="2">
            <TabItem x:Name="QueueTab" Header="Queue">
                <Grid>
                    <DataGrid x:Name="QueueGrid" ItemsSource="{Binding QueuedFiles}" AutoGenerateColumns="False" CanUserAddRows="False"
                              SelectionMode="Extended" SelectionUnit="FullRow" AllowDrop="True" Drop="FileGrid_Drop" DragEnter="FileGrid_DragEnter"
                              Background="Transparent" MouseDoubleClick="FileGrid_MouseDoubleClick" IsReadOnly="True"
                              HeadersVisibility="All" LoadingRow="FileGrid_LoadingRow" PreviewKeyDown="FileGrid_PreviewKeyDown" SelectionChanged="QueueGrid_SelectionChanged">
                        <DataGrid.ContextMenu>
                            <ContextMenu>
                                <MenuItem Header="Open Source Folder" Click="ContextOpenSourceFolder_Click"/>
                                <MenuItem Header="Open Output Folder" Click="ContextOpenOutputFolder_Click"/>
                                <Separator/>
                                <MenuItem Header="Remove Item(s)" Click="ContextRemoveItems_Click"/>
                            </ContextMenu>
                        </DataGrid.ContextMenu>
                        <DataGrid.RowStyle>
                            <Style TargetType="DataGridRow">
                                <Setter Property="Background" Value="{Binding RowBrush}"/>
                                <EventSetter Event="PreviewMouseRightButtonDown" Handler="DataGridRow_PreviewMouseRightButtonDown"/>
                            </Style>
                        </DataGrid.RowStyle>
                        <DataGrid.Columns>
                            <DataGridTemplateColumn Header="Filename" Width="*">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                            <TextBlock Text="⚠️" Foreground="OrangeRed" FontSize="14" VerticalAlignment="Center" Margin="0,0,5,0"
                                                       Visibility="{Binding ShowWarningIcon, Converter={StaticResource BoolToVisConverter}}"
                                                       ToolTip="{Binding WarningTooltipText}"/>
                                            <TextBlock Text="{Binding FileName}" VerticalAlignment="Center"/>
                                        </StackPanel>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                            <DataGridTextColumn Header="Size" Binding="{Binding FileSize}" Width="Auto"/>
                            <DataGridTextColumn Header="Dolby Vision" Binding="{Binding DolbyVisionProfile}" Width="Auto"/>
                            <DataGridTextColumn Header="Audio" Binding="{Binding AudioDescription}" Width="Auto"/>
                            <DataGridTemplateColumn Header="Progress" Width="150">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <ProgressBar Value="{Binding Progress}" IsIndeterminate="{Binding IsIndeterminate}" Minimum="0" Maximum="100" Height="28"/>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                        </DataGrid.Columns>
                    </DataGrid>
                    <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Opacity="0.4" IsHitTestVisible="False" Style="{DynamicResource EmptyHintStyle}"/>
                </Grid>
            </TabItem>
            <TabItem x:Name="HistoryTab" Header="History">
                <DataGrid x:Name="HistoryGrid" ItemsSource="{Binding HistoryFiles}" AutoGenerateColumns="False" CanUserAddRows="False" 
                          IsReadOnly="True" HeadersVisibility="All" LoadingRow="FileGrid_LoadingRow" MouseDoubleClick="FileGrid_MouseDoubleClick">
                    <DataGrid.ContextMenu>
                        <ContextMenu>
                            <MenuItem Header="Open Source Folder" Click="ContextOpenSourceFolder_Click"/>
                            <MenuItem Header="Open Output Folder" Click="ContextOpenOutputFolder_Click"/>
                            <Separator/>
                            <MenuItem Header="Remove Item(s)" Click="ContextRemoveItems_Click"/>
                        </ContextMenu>
                    </DataGrid.ContextMenu>
                    <DataGrid.RowStyle>
                        <Style TargetType="DataGridRow">
                            <Setter Property="Background" Value="{Binding RowBrush}"/>
                            <EventSetter Event="PreviewMouseRightButtonDown" Handler="DataGridRow_PreviewMouseRightButtonDown"/>
                        </Style>
                    </DataGrid.RowStyle>
                    <DataGrid.Columns>
                        <DataGridTemplateColumn Header="Filename" Width="*">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                        <TextBlock Text="⚠️" Foreground="OrangeRed" FontSize="14" VerticalAlignment="Center" Margin="0,0,5,0"
                                                    Visibility="{Binding ShowWarningIcon, Converter={StaticResource BoolToVisConverter}}"
                                                    ToolTip="{Binding WarningTooltipText}"/>
                                        <TextBlock Text="{Binding FileName}" VerticalAlignment="Center"/>
                                    </StackPanel>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                        <DataGridTextColumn Header="Size" Binding="{Binding FileSize}" Width="Auto"/>
                        <DataGridTextColumn Header="Audio" Binding="{Binding AudioDescription}" Width="Auto"/>
                        <DataGridTextColumn Header="Status" Binding="{Binding FinalStatus}" Width="Auto"/>
                    </DataGrid.Columns>
                </DataGrid>
            </TabItem>
        </TabControl>
        <Grid Grid.Row="3" Margin="0,10,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <StackPanel Grid.Column="0" Orientation="Horizontal">
                <Button x:Name="StartButton" Content="Start Conversion" Padding="10,5" FontWeight="Bold" Click="StartConversion_Click"/>
                <Button x:Name="CancelButton" Content="Cancel" Padding="10,5" FontWeight="Bold" IsEnabled="False" Margin="5,0,0,0" Click="CancelConversion_Click"/>
            </StackPanel>
            <Button Grid.Column="2" Style="{DynamicResource BuyMeACoffeeButton}" Click="Donate_Click" ToolTip="Support the developer!" HorizontalAlignment="Right">
                <Image Source="res/bmc_graphic.png" Height="32"/>
            </Button>
        </Grid>
        <StatusBar Grid.Row="4" Margin="0,5,0,0">
            <StatusBarItem>
                <TextBlock x:Name="StatusLabel" Text="Select files to begin."/>
            </StatusBarItem>
        </StatusBar>
    </Grid>
</Window>

